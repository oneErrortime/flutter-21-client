# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/voicecall

# JWT Secrets (CHANGE THESE IN PRODUCTION - use `openssl rand -hex 64`)
JWT_ACCESS_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_ACCESS
JWT_REFRESH_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_REFRESH
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# SSL (for production with nginx, leave empty)
SSL_CERT=
SSL_KEY=

# TURN Server (for production, deploy Coturn or use Metered.ca)
TURN_URLS=turn:your.turn.server:3478
TURN_USERNAME=your_turn_user
TURN_CREDENTIAL=your_turn_password

# App Link Base URL
APP_BASE_URL=https://yourapp.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
