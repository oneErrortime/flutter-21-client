{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.user_id, u.username, u.display_name, u.avatar_url, c.created_at\n        FROM contacts c\n        JOIN users u ON c.target_id = u.user_id\n        WHERE c.requester_id = $1 AND c.status = 'pending'\n        ORDER BY c.created_at DESC\n        ",
