# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://voicecall:strongpassword@localhost:5432/voicecall

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── JWT Secrets (generate: openssl rand -hex 64) ─────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_64_BYTE_HEX_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_64_BYTE_HEX_REFRESH_SECRET
JWT_ACCESS_EXP_SECS=900
JWT_REFRESH_EXP_SECS=2592000

# ── AES-256-GCM Signaling Encryption (generate: openssl rand -hex 32) ────────
SIGNALING_SECRET=CHANGE_ME_32_BYTE_HEX_AES_KEY

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourapp.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://yourapp.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
AUTH_RATE_PER_MINUTE=10
API_RATE_PER_MINUTE=120

# ── TURN Server ───────────────────────────────────────────────────────────────
TURN_URLS=turn:yourapp.com:3478
TURN_USERNAME=turnuser
TURN_CREDENTIAL=strongpassword

# ── Logging (Rust log levels) ─────────────────────────────────────────────────
RUST_LOG=voicecall_server=info,tower_http=info,sqlx=warn
