# ─────────────────────────────────────────────────────────────────────────────
# Stage 1: Build
# ─────────────────────────────────────────────────────────────────────────────
FROM rust:slim-bookworm AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

ENV SQLX_OFFLINE=true

# Cache deps layer — copy manifests first, build dummy binary
COPY Cargo.toml Cargo.lock ./
RUN mkdir src && echo 'fn main(){}' > src/main.rs && \
    cargo build --release && \
    rm -rf src

# Copy .sqlx cache (generated by `cargo sqlx prepare` in CI before this build)
# and actual source, then rebuild touching main.rs to force relink
COPY .sqlx  ./.sqlx
COPY src    ./src
RUN touch src/main.rs && cargo build --release

# ─────────────────────────────────────────────────────────────────────────────
# Stage 2: Runtime (distroless — no shell, ~10MB final image)
# ─────────────────────────────────────────────────────────────────────────────
FROM gcr.io/distroless/cc-debian12:nonroot

COPY --from=builder /build/target/release/voicecall-server /app/voicecall-server

EXPOSE 3000

USER nonroot:nonroot

ENTRYPOINT ["/app/voicecall-server"]
